<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
  @page {
    size: A4 landscape;
    margin: 0.8cm;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: Arial, sans-serif;
    font-size: 9px;
    color: #1a1a2e;
    background: #fff;
  }

  /* ── Lane colours ── */
  .bg-critical { background: #c0392b; color: #fff; }
  .bg-high     { background: #e67e22; color: #fff; }
  .bg-medium   { background: #f39c12; color: #fff; }
  .bg-low      { background: #27ae60; color: #fff; }

  /* ── Card shell ── */
  .card {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    height: calc(100vh - 1.6cm);
    gap: 3px;
  }

  /* ── Header ── */
  .header {
    position: relative;
    padding: 5px 8px;
    border-bottom: 2px solid #1a1a2e;
  }
  .header .finding-id {
    font-size: 13px;
    font-weight: 700;
    display: inline;
  }
  .header .cve-id {
    font-size: 10px;
    color: #444;
    margin-top: 1px;
  }
  .severity-badge {
    position: absolute;
    top: 5px;
    right: 8px;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* ── Component strip ── */
  .component-strip {
    padding: 3px 8px;
    background: #f5f5f5;
    font-size: 8px;
    color: #555;
    border-bottom: 1px solid #ddd;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .component-strip strong { color: #1a1a2e; }

  /* ── Verdict strip ── */
  .verdict-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 10px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.3px;
  }
  .verdict-strip .priority-score {
    font-size: 11px;
    font-weight: 600;
    opacity: 0.92;
  }

  /* ── Main grid ── */
  .main-grid {
    display: grid;
    grid-template-columns: 42% 30% 28%;
    gap: 4px;
    overflow: hidden;
  }
  .col { overflow: hidden; }
  .col-head {
    font-size: 8px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #888;
    padding: 0 0 2px 0;
    border-bottom: 1px solid #ddd;
    margin-bottom: 3px;
  }

  /* ── Signal grid (4 columns: signal · value · applied · score) ── */
  .signal-grid {
    display: grid;
    grid-template-columns: 5.5em 6em 3em 3.5em;
    row-gap: 2px;
    column-gap: 2px;
    font-size: 8.5px;
  }
  .signal-grid .sh {
    font-weight: 600;
    color: #777;
    font-size: 7.5px;
    padding-bottom: 1px;
  }
  .signal-grid .sname { color: #444; }
  .signal-grid .sval  { color: #1a1a2e; font-weight: 600; }
  .signal-grid .sappl { text-align: center; }
  .signal-grid .spts  { text-align: right; font-family: monospace; color: #555; }
  .applied-yes { color: #27ae60; font-weight: 700; }
  .applied-no  { color: #bbb; }
  .applied-mid { color: #e67e22; font-weight: 600; }
  .no-data     { color: #bbb; font-style: italic; }

  /* ── Rationale + Actions + Gaps columns ── */
  .rat-list, .act-list, .gap-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .rat-list li { padding: 1px 0; font-size: 8.5px; color: #333; }
  .rat-list li::before { content: "• "; color: #888; }
  .act-list li { padding: 1px 0; font-size: 8.5px; color: #1a1a2e; }
  .act-list li::before { content: "→ "; color: #e67e22; font-weight: 700; }
  .gap-list li { padding: 1px 0; font-size: 8.5px; color: #555; }
  .gap-list li::before { content: "☐ "; color: #c0392b; }

  .section-sep {
    border: none;
    border-top: 1px solid #eee;
    margin: 4px 0;
  }

  .mitig-entry { margin-bottom: 3px; font-size: 8px; }
  .mitig-entry strong { color: #1a1a2e; }
  .mitig-entry .causal { color: #27ae60; font-style: italic; }

  .pill {
    display: inline-block;
    background: #fdecea;
    color: #c0392b;
    border-radius: 8px;
    padding: 0px 5px;
    font-size: 7.5px;
    margin: 1px 1px 0 0;
  }

  /* ── Footer ── */
  .footer {
    border-top: 1px solid #ddd;
    padding-top: 3px;
    display: flex;
    justify-content: space-between;
    font-size: 7px;
    font-family: monospace;
    color: #aaa;
  }
</style>
</head>
<body>
<div class="card">

  <!-- Header -->
  <div class="header">
    <span class="finding-id">{{ finding.id }}</span>
    <div class="cve-id">{{ finding.cve_or_id }}{% if finding.title %} — {{ finding.title }}{% endif %}</div>
    <span class="severity-badge bg-{{ assessment.lane }}">{{ assessment.lane | upper }}</span>
  </div>

  <!-- Component strip -->
  <div class="component-strip">
    <strong>{{ finding.component.name }}</strong>
    {{ finding.component.version or "" }}
    · {{ finding.component.type }}
    · {{ finding.entry_point.description }}
    {% if finding.environment and finding.environment.stage %} · {{ finding.environment.stage }}{% endif %}
    {% for u in finding.attacker_utility %}<span class="pill">{{ u }}</span>{% endfor %}
  </div>

  <!-- Verdict strip -->
  <div class="verdict-strip bg-{{ assessment.lane }}">
    <span>
      ⬤&nbsp;
      {% if assessment.target.days is not none %}REMEDIATE IN {{ assessment.target.days }} HOUR{% if assessment.target.days != 1 %}S{% endif %}{% else %}SCHEDULE FOR PATCH TRAIN{% endif %}
    </span>
    <span class="priority-score">
      {% if assessment.priority_score is not none %}Priority: {{ assessment.priority_score }} / 10{% endif %}
    </span>
  </div>

  <!-- Main 3-column grid -->
  <div class="main-grid">

    <!-- Col 1: Intel signals -->
    <div class="col">
      <div class="col-head">Intel Signals</div>
      <div class="signal-grid">
        <!-- Header row -->
        <span class="sh">Signal</span>
        <span class="sh">Value</span>
        <span class="sh" style="text-align:center">Applied</span>
        <span class="sh" style="text-align:right">Score Δ</span>

        <!-- CVSS -->
        <span class="sname">CVSS</span>
        <span class="sval">{% if intel.cvss %}{{ intel.cvss.base }} v{{ intel.cvss.version }}{% else %}<span class="no-data">—</span>{% endif %}</span>
        <span class="sappl">{% if intel.cvss %}<span class="applied-yes">✓</span>{% else %}<span class="applied-no">—</span>{% endif %}</span>
        <span class="spts">{% if assessment.priority_score_breakdown %}+{{ assessment.priority_score_breakdown.cvss }}{% else %}—{% endif %}</span>

        <!-- KEV -->
        <span class="sname">CISA KEV</span>
        <span class="sval">{% if intel.kev and intel.kev.listed %}<strong>Listed</strong>{% elif intel.kev %}Not listed{% else %}<span class="no-data">—</span>{% endif %}</span>
        <span class="sappl">{% if intel.kev and intel.kev.listed %}<span class="applied-yes">✓</span>{% else %}<span class="applied-no">—</span>{% endif %}</span>
        <span class="spts">{% if assessment.priority_score_breakdown and intel.kev and intel.kev.listed %}+1.5{% else %}—{% endif %}</span>

        <!-- EPSS -->
        <span class="sname">EPSS</span>
        <span class="sval">{% if intel.epss %}{{ "%.0f"|format(intel.epss.percentile * 100) }}th pct{% else %}<span class="no-data">—</span>{% endif %}</span>
        <span class="sappl">{% if intel.epss and intel.epss.score >= 0.5 %}<span class="applied-yes">✓</span>{% elif intel.epss and intel.epss.score >= 0.1 %}<span class="applied-mid">⚠</span>{% else %}<span class="applied-no">—</span>{% endif %}</span>
        <span class="spts">{% if intel.epss and intel.epss.score >= 0.5 %}+1.0{% elif intel.epss and intel.epss.score >= 0.1 %}+0.5{% else %}—{% endif %}</span>

        <!-- Reachability -->
        <span class="sname">Reachability</span>
        <span class="sval">{{ finding.reachability | replace("_", " ") }}</span>
        <span class="sappl">{% if finding.reachability == "internet_exposed" %}<span class="applied-yes">✓</span>{% elif finding.reachability == "constrained" %}<span class="applied-mid">⚠</span>{% else %}<span class="applied-no">—</span>{% endif %}</span>
        <span class="spts">{% if assessment.priority_score_breakdown %}+{{ assessment.priority_score_breakdown.reachability }}{% else %}—{% endif %}</span>

        <!-- Utility -->
        <span class="sname">Utility</span>
        <span class="sval">{% if assessment.score_breakdown %}{{ assessment.score_breakdown.utility | upper }}{% else %}<span class="no-data">—</span>{% endif %}</span>
        <span class="sappl">{% if assessment.score_breakdown and assessment.score_breakdown.utility == "high" %}<span class="applied-yes">✓</span>{% else %}<span class="applied-no">—</span>{% endif %}</span>
        <span class="spts">{% if assessment.priority_score_breakdown %}+{{ assessment.priority_score_breakdown.utility }}{% else %}—{% endif %}</span>

        <!-- Mitigations -->
        <span class="sname">Mitigations</span>
        <span class="sval">{% if assessment.score_breakdown %}{{ assessment.score_breakdown.mitigation_effect }}{% else %}<span class="no-data">—</span>{% endif %}</span>
        <span class="sappl">{% if assessment.score_breakdown and assessment.score_breakdown.mitigation_effect == "strong" %}<span class="applied-yes">✓</span>{% elif assessment.score_breakdown and assessment.score_breakdown.mitigation_effect == "partial" %}<span class="applied-mid">⚠</span>{% else %}<span class="applied-no">—</span>{% endif %}</span>
        <span class="spts">{% if assessment.priority_score_breakdown %}{{ assessment.priority_score_breakdown.mitigation_penalty }}{% else %}—{% endif %}</span>
      </div>

      {% if finding.mitigations %}
      <hr class="section-sep">
      <div style="font-size:7.5px; color:#888; text-transform:uppercase; font-weight:700; margin-bottom:2px;">Mitigations</div>
      {% for m in finding.mitigations %}
      <div class="mitig-entry">
        <strong>{{ m.type }}</strong> — {{ m.description }}
        {% if m.causal_claim %}<br><span class="causal">✓ {{ m.causal_claim }}</span>{% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </div>

    <!-- Col 2: Rationale -->
    <div class="col">
      <div class="col-head">Rationale</div>
      <ul class="rat-list">
        {% for r in assessment.rationale %}<li>{{ r }}</li>{% endfor %}
      </ul>

      {% if evidence %}
      <hr class="section-sep">
      <div style="font-size:7.5px; color:#888; text-transform:uppercase; font-weight:700; margin-bottom:2px;">Evidence</div>
      {% for e in evidence %}
      <div style="font-size:8px; padding:1px 0; color:#555;">
        {% if e.verified %}<span style="color:#27ae60;">✓</span>{% else %}<span style="color:#c0392b;">✗</span>{% endif %}
        {{ e.claim }} <span style="color:#aaa;">({{ e.type }})</span>
      </div>
      {% endfor %}
      {% endif %}
    </div>

    <!-- Col 3: Actions + Gaps -->
    <div class="col">
      <div class="col-head">Required Actions</div>
      <ul class="act-list">
        {% for a in assessment.actions %}<li>{{ a }}</li>{% endfor %}
      </ul>

      {% if assessment.evidence_gaps %}
      <hr class="section-sep">
      <div class="col-head" style="margin-top:3px;">Evidence Gaps</div>
      <ul class="gap-list">
        {% for g in assessment.evidence_gaps %}<li>{{ g }}</li>{% endfor %}
      </ul>
      {% endif %}
    </div>

  </div><!-- /main-grid -->

  <!-- Footer: score formula + metadata -->
  <div class="footer">
    <span>
      {% if assessment.priority_score_breakdown %}
      Score: {{ assessment.priority_score_breakdown.cvss }}(cvss)
      + {{ assessment.priority_score_breakdown.reachability }}(reach)
      + {{ assessment.priority_score_breakdown.intel }}(intel)
      + {{ assessment.priority_score_breakdown.utility }}(util)
      {{ assessment.priority_score_breakdown.mitigation_penalty }}(mit)
      = {{ assessment.priority_score_breakdown.total }}
      {% endif %}
    </span>
    <span>{{ assessment.policy_version }} · {{ finding.id }}</span>
    <span>For authorized security team review only · {{ generated_at }}</span>
  </div>

</div><!-- /card -->
</body>
</html>
