# RubricAI environment configuration
# Copy to .env and fill in values before running

# MCP transport: stdio (Claude Desktop) or sse (Docker/remote)
RUBRICAI_TRANSPORT=stdio

# Directory where generated report cards are persisted
RUBRICAI_REPORT_DIR=./reports

# Optional: NVD API key — increases rate limit from 5 to 50 req/30s
# Register at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Lane remediation targets (optional overrides)
# Set to an integer (days) for a fixed SLA, or "patch_train" for no fixed SLA.
# Defaults: Critical=3, High=7, Medium=patch_train, Low=patch_train
#RUBRICAI_CRITICAL_DAYS=3
#RUBRICAI_HIGH_DAYS=7
#RUBRICAI_MEDIUM_DAYS=patch_train
#RUBRICAI_LOW_DAYS=patch_train
